
// Patch to add Sync button support
// Place after existing code definitions in players.js
const btnSync = document.getElementById('p.sync');
if (btnSync) {
  btnSync.onclick = async () => {
    try {
      // Call the Edge Function using your project URL from config.js
      const url = window.SUPABASE_URL.replace(/\/$/, '') + '/functions/v1/sync-players';
      const resp = await fetch(url, {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ mode: 'demo' }) // change to { mode:'provider', provider:'api-sports', players:[...] } later
      });
      const json = await resp.json();
      if (!resp.ok || json.ok === false) throw new Error(json.error || 'Sync failed');
      alert('Sync complete: ' + json.count + ' rows');
      loadPlayers();
    } catch (e) {
      alert('Sync failed: ' + e.message);
    }
  };
}
